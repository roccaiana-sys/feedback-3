  6: { qs: 4, req: ['q61sat','q62pret','q63nps'] }
};
const ALL_REQ = ['q11','q12','q22','q23ssm','q24zona','q31scule','q32cons','q33comp','q34preg','q41prez','q42cond','q43curat','q51foaie','q52expl','q54transp','q61sat','q62pret','q63nps'];
const ans = {};

// ── Scale / NPS buttons ───────────────────────────
document.querySelectorAll('.sb,.nb').forEach(btn => {
  btn.addEventListener('click', function(){
    const q = this.dataset.q;
    document.querySelectorAll(`[data-q="${q}"]`).forEach(b => b.classList.remove('active'));
    this.classList.add('active');
    ans[q] = this.dataset.val;
    updateProgress();
  });
});

// ── Radio ─────────────────────────────────────────
document.querySelectorAll('.opt input[type="radio"]').forEach(r => {
  r.addEventListener('change', function(){
    const n = this.name;
    document.querySelectorAll(`input[name="${n}"]`).forEach(x => x.closest('.opt').classList.remove('sel'));
    this.closest('.opt').classList.add('sel');
    ans[n] = this.value;
    updateProgress();
    // follow-ups
    if(n==='q25int') document.getElementById('fup-q25').classList.toggle('on', this.value==='Da');
    if(n==='q31scule') document.getElementById('fup-q31').classList.toggle('on', this.value==='Da');
    if(n==='q32cons') document.getElementById('fup-q32').classList.toggle('on', this.value==='Da');
    if(n==='q33comp') document.getElementById('fup-q33').classList.toggle('on', this.value==='Da');
    if(n==='q51foaie') document.getElementById('fup-q51').classList.toggle('on', this.value==='Nu');
  });
});

// ── Stars ─────────────────────────────────────────
document.querySelectorAll('.stars input').forEach(r => {
  r.addEventListener('change', function(){ ans[this.name]=this.value; updateProgress(); });
});

// ── Navigation ────────────────────────────────────
function showQ(cat, q){
  const body = document.querySelector(`#cat-${cat} .cat-body`);
  body.querySelectorAll('.qw').forEach(w => w.classList.remove('visible'));
  const t = document.getElementById(`q-${cat}-${q}`);
  if(t){ t.classList.add('visible'); setTimeout(()=> t.scrollIntoView({behavior:'smooth',block:'nearest'}),50); }
}

function goNext(cat, cur){
  const max = CAT_CONFIG[cat].qs;
  if(cur < max) showQ(cat, cur+1);
}
function goPrev(cat, cur){
  if(cur > 1) showQ(cat, cur-1);
}

// ── Finish category — validates required in cat ───
function finishCat(cat){
  const req = CAT_CONFIG[cat].req;
  const missing = req.filter(q => !ans[q]);

  if(missing.length > 0){
    // find first missing question and show it
    const firstMissing = missing[0];
    const qEl = document.querySelector(`[name="${firstMissing}"], [data-q="${firstMissing}"]`);
    if(qEl){
      // find which question-wrap it's in
      const qwrap = qEl.closest('.qw');
      if(qwrap){
        const qId = qwrap.id; // e.g. "q-2-3"
        const parts = qId.split('-');
        showQ(parseInt(parts[1]), parseInt(parts[2]));
      }
    }
    showMissingAlert(missing.length);
    return;
  }

  // close & mark done
  const block = document.getElementById(`cat-${cat}`);
  block.classList.remove('active');
  const st = document.getElementById(`st-${cat}`);
  st.textContent = '✓ Completat';
  st.classList.add('done');

  const next = cat + 1;
  if(next <= 6){
    const nb = document.getElementById(`cat-${next}`);
    nb.classList.add('active');
    setTimeout(()=> nb.scrollIntoView({behavior:'smooth',block:'start'}),100);
  }
  updateProgress();
}

function showMissingAlert(count){
  const msg = count === 1
    ? 'Mai este 1 întrebare obligatorie necompletată în această secțiune.'
    : `Mai sunt ${count} întrebări obligatorii necompletate în această secțiune.`;
  // simple non-blocking inline approach — brief flash on button
  const btn = document.activeElement;
  if(btn){ btn.textContent='⚠ Completați toate câmpurile'; setTimeout(()=>{ btn.textContent='Finalizează secțiunea ✓'; },2000); }
}

// ── Progress ──────────────────────────────────────
function updateProgress(){
  const done = ALL_REQ.filter(q => ans[q]).length;
  document.getElementById('pfill').style.width = (done/ALL_REQ.length*100)+'%';
}

// ── Submit ────────────────────────────────────────
function submitForm(){
  const missing = ALL_REQ.filter(q => !ans[q]);
  if(missing.length > 0){
    alert(`Mai sunt ${missing.length} câmpuri obligatorii necompletate. Vă rugăm reveniți asupra secțiunilor anterioare.`);
    return;
  }

  const data = {
    timestamp: new Date().toISOString(),
    email: document.getElementById('f-email').value || '',
    locatie: document.getElementById('f-location').value || '',
    ...ans,
    q25_detail: document.getElementById('q25-detail')?.value||'',
    q31_detail: document.getElementById('q31-detail')?.value||'',
    q32_detail: document.getElementById('q32-detail')?.value||'',
    q33_detail: document.getElementById('q33-detail')?.value||'',
    q51_contact: document.getElementById('q51-contact')?.value||'',
    q64_obs: document.getElementById('q64obs')?.value||''
  };

  const SHEETS_URL = 'YOUR_APPS_SCRIPT_URL';
  fetch(SHEETS_URL,{method:'POST',mode:'no-cors',headers:{'Content-Type':'application/json'},body:JSON.stringify(data)}).catch(()=>{});

  // show closing page
  document.getElementById('formPage').style.display = 'none';
  document.getElementById('closingPage').classList.add('on');
  document.getElementById('pfill').style.width = '100%';
  window.scrollTo({top:0,behavior:'smooth'});
}
</script>
</body>
</html>
